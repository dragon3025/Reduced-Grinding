				}

				SuperBobberPotionAlternateIngredient: {
					Label: "{$Configs.BobberPotionConfig.BobberPotionAlternateIngredient.Label}"
					Tooltip: "{$Configs.BobberPotionConfig.BobberPotionAlternateIngredient.Tooltip}"
				}

				SuperBobberPotionBonus: {
					Label: "{$Configs.BobberPotionConfig.BobberPotionBonus.Label}"
