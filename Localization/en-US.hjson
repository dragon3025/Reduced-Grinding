			TimeAndWeatherConfig: {
				DisplayName: 10 [i:ReducedGrinding/MoonWatch] Time and Weather

				MoonWatchMaterial: {
					Label: "[i:ReducedGrinding/MoonWatch] Moon Watch Material"
					Tooltip:
						'''
						This item is consumed on use and will advance the moon phase to the next phase.
						{$Misc.ConfigurationTooltips.MainIngredient}
						'''
				}

				MoonWatchMaterialAmount: {
					Label: "[i:ReducedGrinding/MoonWatch] Moon Watch Material Amount"
					Tooltip: Set the amount of "Moon Watch Material" required to craft.
				}

				MoonWatchAlternateMaterial: {
					Label: "[i:ReducedGrinding/MoonWatch] Moon Watch Alternate Material"
					Tooltip: "{$Misc.ConfigurationTooltips.AlternateIngredient}"
				}

				Headers.EnchantedSundial: "[i:3064] Enchanted Sundial"

				CrateEnchantedSundial: {
					Label: "[i:3981] Average Crates to Get"
					Tooltip:
						'''
						Changes the chance of Enchanted Sundial drop from Crates that drop it. Chance =
						1 / setting. This is multiplied by 3 for Mythril and 10 for Pearlwood. The
						vanilla default is 20.

						Consider "Bobber Potions" when setting this.
						'''
				}

				PreHardmodeSundials: {
					Label: "[i:2336] Pre-Hardmode Sundials"
					Tooltip:
						'''
						If enabled, all Vanilla pre-Hardmode Crates will have the same chance
						of dropping Enchanted Sundial that their Hardmode variant has

						Consider "Bobber Potions" when setting this.
						'''
				}

				EnchantedDialCooldown: {
					Label: Enchanted Dial Cooldown
					Tooltip: The vanilla default is 7.
				}

				SleepRateMultiplier: {
					Label: "[i:224] Sleep Time Rate Multiplier"
					Tooltip:
						'''
						In vanilla, sleeping multiplies the time rate by 5;
						afterward it will be multiplied by this amount.
						'''
				}

				ItemShimmeredForWind: {
					Label: "[i:PinWheel] Item Shimmered For Wind"
					Tooltip:
						'''
						When the item set here is Shimmered, it will be consumed, increase the
						world's wind speed to the maximum amount (rain will increase this further), and
						cause a sandstorm. Set to None, to disable.
						[c/FFA600:Don't set this to an item that already transforms, decrafts, or does something]
						[c/FFA600:else when shimmered; doing so could disable that affect].
						'''
				}

				ItemShimmeredForRain: {
					Label: "[i:RainHat] Item Shimmered For Rain"
					Tooltip:
						'''
						When the item set here is Shimmered, it will be consumed and increase the worlds
						rain to the maximum amount. Set to None, to disable.
						[c/FFA600:Don't set this to an item that already transforms, decrafts, or does something]
						[c/FFA600:else when shimmered; doing so could disable that affect].
						'''
				}

				EnchantedDialMultiplier: {
					Label: Enchanted Dial Time Rate Multiplier
					Tooltip:
						'''
						In vanilla, enchanted dials multiplies the time rate by 60;
						afterward it will be multiplied by this amount
						'''
				}
			}

			OtherConfig: {
				DisplayName: 11 [i:Shimmerfly] Other

				Headers: {
					StaffOfDifficulty:
						'''
						Staff of Difficulty

						There is a staff for [i:ReducedGrinding/ClassicStaff] [c/FFFFFF:{$UI.Normal}], [i:ReducedGrinding/ExpertStaff] [c/FF9900:{$UI.Expert}], [i:ReducedGrinding/MasterStaff] [c/FF2619:{$UI.Master}]. Using a staff will change the world difficulty to match the staff. In "For the Worthy" worlds, the difficulty will be increased by 1 level afterward. In multiplayer worlds, the staves will vote to change the world difficulty and the difficulty will only change it if enough players vote to change it.
						'''
					FaelingHelper:
						'''
						[i:Shimmerfly] Faeling Helper

						If the Aether hasn't been found, Faelings will replace critter spawns under the conditions configured below. These Faelings can't be caught. Once you're close enough, they will fly towards the Aether at an accelerating speed. Set either values to 0, to disable.
						'''
				}

				PlaceableLog: {
					Label: "[i:ReducedGrinding/PlaceableLog] Placeable Log"
					Tooltip: A log that you can place, which will turn into a working Fallen Log over time.
				}

				DifficultyStavesVoteTimeSeconds: {
					Tooltip: ""
					Label: Vote Time in Seconds
				}

				DifficultyStavesVotesRequired: {
					Tooltip:
						'''
						In multiplayer worlds, the difficulty will only change if the percentage of
						players that voted to change the difficulty is greater than or equal to this.
						'''
					Label: Votes Required
				}

				DifficultyStavesEnabled: {
					Tooltip: ""
					Label: Enabled
				}

				AdjustItemValuesForDropIncreases: {
					Label: "[i:GoldCoin] Adjust Values"
					Tooltip:
						'''
						If enabled, this mod will adjust item values if their loot
						rates have been changed
						'''
				}

				ClairvoyanceShowsLuck: {
					Label: "[i:487] Clairvoyance Shows Luck"
					Tooltip: The Clairvoyance Buff displays Luck
				}

				LocatingInfoShowsDirection: {
					Label: "[i:LifeformAnalyzer] Locating Accessories Shows Direction [i:MetalDetector]"
					Tooltip:
						'''
						Lifeform Analyzer and Metal Detector will display a triangular
						arrow showing the direction of the object it's detecting.
						'''
				}

				ConvenientNPCRarity: {
					Label: "[i:LifeformAnalyzer] Convenient NPC Rarity"
					Tooltip:
						'''
						If a player doesn't have Metal Detector or its upgrades, the Lost Girl and
						Nymph's Lifeform Analyzer Rarity will be 6 instead of 2, which makes it take
						priority over all other vanilla NPCs. If a player hasn't eaten an Artisan Loaf,
						the Skeleton's Merchant's rarity will be 3 instead of 1.
						'''
				}

				AmberMosquitoChance: {
					Label: "[i:AmberMosquito] Amber Mosquito From [i:3347] Desert Fossil"
					Tooltip:
						'''
						When using Desert Fossil at any type of Extractinator, if the item given isn't
						Sturdy Fossil, the chance the item given will be replaced by Amber Mosquito is 1
						divided by n, where n is this setting. The vanilla chance of Amber Mosquito
						dropping is still there, so this is a bonus chance. Set to 0 to disable.
						'''
				}

				SliceOfCakeDuration: {
					Label: "[i:SliceOfCake] Slice Of Cake Duration"
					Tooltip:
						'''
						Set the duration in minutes for Slice of Cake. Set to 2 to use
						the vanilla duration. Set to 61 to make the duration infinite.
						'''
				}

				FaelingHelperLimit: {
					Label: Faeling Helper Limit
					Tooltip: The helping Faelings wont spawn if there's at least this many Faelings existing.
				}

				FaelingHelperRange: {
					Label: Faeling Helper Range
					Tooltip:
						'''
						The helping Faelings wont spawn unless the critter they would replace is within
						a certain distance of the Aether. The distance equals the width of the world
						multiplied by this amount.
						'''
				}

				EarlyUniPylonNerf: {
					Label: "[i:4951] Early Universal Pylon Nerf"
					Tooltip:
						'''
						This mod provides ways to get the Universal Pylon early, but that could also
						make Potion of Return useless early. If enabled, the Universal Pylon will
						require 2 nearby NPCs, until Bestiary is 100% complete.
						'''
				}
			}

			BattlePotionConfig: {
				DisplayName: 02 [i:BattlePotion] Battle Potions

				GreaterBattlePotion: {
					Label: "[i:ReducedGrinding/GreaterBattlePotion] Greater Battle Potion"
					Tooltip: ""
				}

				SuperBattlePotion: {
					Label: "[i:ReducedGrinding/SuperBattlePotion] Super Battle Potion"
					Tooltip: ""
				}

				Headers: {
					BatttleBuffDuration: Batttle Buff Duration
					BattlePotions: Spawn Rate Presets
					BattleBuffSpawnRates: Battle Buff Spawn Rate Multipliers
				}

				VanillaDuration: {
					Label: "[i:BattlePotion] Battle Potion Duration"
					Tooltip: ""
				}

				GreaterDuration: {
					Label: "[i:ReducedGrinding/GreaterBattlePotion] Greater Battle Potion Duration"
					Tooltip: ""
				}

				SuperDuration: {
					Label: "[i:ReducedGrinding/SuperBattlePotion] Super Battle Potion Duration"
