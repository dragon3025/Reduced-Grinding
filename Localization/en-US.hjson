			EventAndBossConfig: {
				DisplayName: 06 [i:BossMaskCultist] Events And Bosses

				OldManVoodooDoll: {
					Tooltip:
						'''
						Keep in your inventory to allow the Dungeon Guardian to spawn after defeating
						Skeletron.
						'''
					Label: "[i:ReducedGrinding/OldManVoodooDoll] Old Man Voodoo Doll"
				}

				WorldPeaceStandard: {
					Label: "[i:ReducedGrinding/WorldPeaceStandard] World Peace Standard"
					Tooltip: Cancels invasions
				}

				WarStandardDuration: {
					Label: "[i:ReducedGrinding/WarStandard] War Standard Duration in Minutes"
					Tooltip:
						'''
						Adds a buff that freezes the progress of invasions. If Greater Battle Potion is
						enabled, it will allow Greater or Super Battle Potion to work during an
						invasion.
						'''
				}

				HolidaySummons: {
					Label: "[i:ReducedGrinding/NicePresent] Nice Present and [i:ReducedGrinding/PumpkinPieMedallion] Pumpkin Pie Medallion"
					Tooltip: Activates Christmas / Halloween.
				}

				LunarSigil: {
					Label: "[i:ReducedGrinding/LunarSigil] Lunar Sigil, Material Dropped by the Lunatic Cultist"
					Tooltip:
						'''
						Summons the Lunar Events. After defeating Moon Lord, the Lunatic Cultist will
						drop "[I:ReducedGrinding/LunarTablet] Lunar Tablet" which can be crafted into Lunar Sigil. Set the amount
						of Lunar Tablet dropped. Set to 0 to disable.
						'''
				}

				CelestialWard: {
					Label: "[i:ReducedGrinding/CelestialWard] Celestial Ward"
					Tooltip: A post-Moon Lord item that removes Celestial Pillars and stops Moon Lord.
				}

				PlanteraSapFromPlantera: {
					Label: "[i:ReducedGrinding/PlanteraSap] Plantera Sap from Plantera, {$Misc.AverageKillsToGet}"
					Tooltip: Summons Plantera. Chance = 1 / setting. Set to 0 to disable.
				}

				NPCArrivalMessages: {
					Label: Respawn messages for [i:RedHat] Old Man and [i:BossMaskCultist] Cultists
					Tooltip:
						'''
						Announcements in the chat that let you know
						that the Old Man or the Cultists respawned.
						'''
				}
			}

			VillagersAndEnemiesConfig: {
				DisplayName: 07 [i:GreenCap] Villagers And Enemies

				NameTag: {
					Label: "[i:ReducedGrinding/NameTag] Name Tag"
					Tooltip: Changes a nearby Town NPC's name. Sold by the Merchant.
				}

				CultMembershipCard: {
					Label: "[i:ReducedGrinding/CultMembershipCard] Cult Membership Card"
					Tooltip:
						'''
						Prevents you from harming Cultist while active. Can be right clicked to toggle
						whether its function is active or inactive. Dropped by the Lunatic Cultist.
						'''
				}

				Headers.ChaosElementalSwarm:
					'''
					[i:1326] Chaos Elemental Swarm

					Defeating the Queen Slime will cause a Chaos Elemental Swarm Event in the Underground Hallow, which increases the rate of Chaos Elemental and Enchanted Sword Spawns. By default, Chaos Elementals will spawn more than Enchanted Swords.
					'''

				CESwarmDuration: {
					Label: Duration
					Tooltip: Duration in minutes. Set to 0 to disable this feature.
				}

				CESwarmCElementalSpawnFailRate: {
					Label: "[i:1629] Chaos Elemental Spawn Fail Rate"
					Tooltip:
						'''
						Chaos Elementals will try replace default spawns. The chance
						that this fails is 1 / n, where n = this setting.
						'''
				}

				CESwarmESwordSpawnFailRate: {
					Label: "[i:1642] Enchanted Sword Spawn Fail Rate"
					Tooltip:
						'''
						If a Chaos Elemental fails to replace a default spawn, an Enchanted Sword will
						try to replace the default spawn instead. The chance that this fails is 1 / n,
						where n = this setting.
						'''
				}

				CESKnockbackResist: {
					Label: Knockback Resist
					Tooltip:
						'''
						During the event, Chaos Elementals will have this knockback resistance.
						The vanilla default is 0.6. 1 = full resistance.
						'''
				}

				UniPylonBestiaryCompletionRate: {
					Label: "[i:4951] Bestiary Completion Rate For Universal Pylon"
					Tooltip: Vanilla Default: 1
				}

				AllowSpawningRegularMimics: {
					Label: Allow spawning [i:306] Regular and [i:681] Ice Mimics
					Tooltip:
						'''
						If enabled, placing nothing but 1 Key of Light and 1 Key of Night in a chest
						will spawn a regular Mimic. Doing this in a Snow Biome will spawn an Ice Mimic.
						After the Mimic is spawned, it will refund 7 to 8 of each Soul of Light and Soul
						of Night.
						'''
				}

				WitchDoctorSellsChlorophyteOre: {
					Label: Witch Doctor Sells [i:947] Chlorophyte Ore
					Tooltip: He will only sell it in the Jungle after beating Plantera
				}

				JackStatue: {
					Label: "[i:ReducedGrinding/JackStatue] Jack Statue"
					Tooltip:
						'''
						Crafted with Stone and requires having King Statue and Queen Statue, but the
						statues aren't consumed when crafting. Teleports all villagers back to their
						homes.
						'''
				}
			}

