			GuaranteedBiomeKeyBehaviorEnums: {
				Tooltip: ""

				GiveOneTime: {
					Label: Give One Time
					Tooltip: Only drop each guaranteed Biome Key 1 time.
				}

				GiveMultipleTimes: {
					Label: Give Multiple Times
					Tooltip:
						'''
						After dropping a guaranteed Biome Key, the kill count for
						it will be reset, which will allow it to drop again.
						'''
				}

				GiveMultipleTimesDisableVanilla: {
					Label: Multiple, Disable Vanilla
					Tooltip:
						'''
						After dropping a guaranteed Biome Key, the kill count for it will be reset,
						which will allow it to drop again.

						Removes the chance for Biome Keys to drop from enemies the vanilla way.
						'''
				}
			}

			AnglerConfig: {
				DisplayName: 03 [i:AnglerHat] Angler

				UnlimitedAnglerQuest: {
					Label: Unlimited Angler Quests
					Tooltip:
						'''
						The angler will always have another quest instead of once per day. If a player
						finished their Quest, the Angler will wait until no player has the current Quest
						Fish in their inventory before giving the next Quest of the current day.
						'''
				}

				AnglerTellsQuestCompleted: {
					Label: Angler Dialogue Tells Player the Amount of Quest Completed
					Tooltip: ""
				}

				AnglerChatsCurrentQuest: {
					Label: "[i:AnnouncementBox] Clicking Quest Will Announce The Current Quest Item"
					Tooltip:
						'''
						This includes an icon, which displays the name and catch
						location when you hover your mouse over it.
						'''
				}

				ShimmerHoneyRewards: {
					Label: "[i:HoneyAbsorbantSponge] Honey Absorbant Sponge can swap with [i:BottomlessHoneyBucket] Bottomless Honey Bucket"
					Tooltip: By using the Shimmer.
				}

				BumblebeeTunaSwapChance: {
					Label: "[i:BeeMask][i:2451] Bumblebee Tuna Swap Chance"
					Tooltip:
						'''
						If you kill the Queen Bee, the current Angler Quest will have this chance to
						change to Bumblebee Tuna. This wont happen if any player has the current Quest
						Fish or if all players have finished the current Quest.

						Set to 0 to disable.
						'''
				}

				Headers: {
					ExtraQuestRewardModifying: Extra Quest Reward Modifying
					HoneyRewards:
						'''
						Honey Rewards

						Getting honey quest rewards is different because the chance is high, but relies on the Quest being Bumblebee Tuna.
						'''
				}

				LowQualityRemovalChance: {
					Label: "[i:2354] Minor Reward Removal Chance"
					Tooltip:
						'''
						This excludes the Anglers's first quest of the current day. If this chance
						passes, vanilla potions and bait will be removed. Set to 0 to disable.
						'''
				}

				CoinMultiplier: {
					Label: "[i:73] Coin Reward Multiplier"
					Tooltip:
						'''
						This excludes the Anglers's first quest of the current day. Coins rewarded will
						be multiplied by this amount (using the total value). Set to 1 to disable.
						'''
				}

				AnglerChatsBumbleBeeTuna: {
					Label: "[i:AnnouncementBox][i:BumblebeeTuna] Angler Will Announce When The New Day Quest is Bumblebee Tuna"
					Tooltip: ""
				}
			}

			CraftingConfig: {
				DisplayName: 09 [i:TinkerersWorkshop] Crafting

				SturdyFossilsToDesertFossils: {
					Label: "[i:DesertFossil] Desert Fossils for every 13 [i:FossilOre] Sturdy Fossils"
					Tooltip:
						'''
						Allow crafting Desert Fossil using 13 Sturdy Fossil. Sturdy Fossil yeild per 100
						Desert Fossils is 13, so setting this to 100 will give a full refund on average.
						Set to 0 to disable.
						'''
				}

				LeatherPerArchaeologistsPiece: {
					Label: "[i:Leather] Leather Per [i:ArchaeologistsJacket] Archaeologists Piece"
					Tooltip: The vanilla default is 15.
				}

				CraftableGoldCritters: {
					Label: Allow crafting [i:2889] Gold Critters
					Tooltip:
						'''
						Recipes use 14 Gold Coins to prevent exploiting
						the recipe for money
						'''
				}

				ShimmerRoyalStatues: {
					Label: "[i:476] King Statue can swap with [i:477] Queen Statue"
					Tooltip: By using the Shimmer.
				}

				Headers.CraftableUniversalPylon: "[i:4951] Craftable Universal Pylon. Recipe will be disabled if all ingredient configurations are disabled."

				UniPylonCraftWithPylons: {
					Label: Craft With [i:4876] Vanilla Pylons
					Tooltip: ""
				}

				UniPylonCraftWithMechSouls: {
					Label: Craft With [i:547] Mech Boss Souls
					Tooltip: Soul of Might, Fright, and Sight
				}

				UniPylonCraftWithFragments: {
					Label: Craft With [i:3457] Lunar Fragments
					Tooltip: ""
				}
			}

			LimitedItemsConfig: {
				DisplayName: 08 [i:Terragrim] Limited Items

				Headers: {
					WorldGeneration: "[i:WorldGlobe] World Generation"
					Other: Other
				}

				TerragrimChestChance: {
					Label: "[i:4144] Chest Terragrim Chance, Average Chests to Find"
					Tooltip:
						'''
						Every chest will have a chance of generating with Terragrim, except for surface
						chest and Living Wood chests. Chance = 1 / setting. Unless this feature is
						disabled, this mod will try to force at least 1 non-Lihzahrd, non-locked chest
						to generate with Terragrim. Set to 0 to disable.
						'''
				}

				AddMissingTreeLoot: {
					Label: "[i:831] Add Missing Living Wood Chest Loot"
					Tooltip:
						'''
						During world generation, this mod will place the
						following items that the world is missing:
						- Ladybug Minecart
						- Sunflower Minecart
						'''
				}

				AddMissingShroomLoot: {
					Label: "[i:2544] Add Missing Mushroom Chest Loot"
					Tooltip:
						'''
						During world generation, this mod will place the
						following items that the world is missing:
						- Shroom Minecart
						- Mushroom vanity set
						'''
				}

				AddMissingPyramidLoot: {
					Label: "[i:934] Add Missing Pyramid Chest Loot"
					Tooltip:
						'''
						During world generation, this mod will place the
						following items that the world is missing:
						- Flying Carpet
						- Pharoah's vanity set
						'''
				}

				TombstonesPerWorld: {
					Label: "[i:321] Tombstones To Generate Per World"
					Tooltip: This amount is multiplied by 16/21 for medium worlds and 1/2 for small worlds.
				}

				OtherEvilChest: {
					Label: "[i:CorruptionChest] Other Evil Chest [i:CrimsonChest]"
					Tooltip: World generation will place both Corrupt and Crimson Chests
				}

				CraftableRareChests: {
					Label: Craftable [i:328] Rare Chests
					Tooltip:
						'''
						Allows Shimmering Shadow Key to and from Shadow Chests. Adds crafting recipes
						for Gold Chest, Dead Man's Chest, Ivy Chest, and Web Covered Chest.
						'''
				}

				TombstonesDropFromNPCs: {
					Label: "[i:321] Tombstones Drop From Town NPCs without Hardcore Characters"
					Tooltip: ""
				}

				DryadSellsOppositeEvilPlanter: {
					Label: "[i:CorruptPlanterBox] Dryad Sells Opposite Evil Planter [i:CrimsonPlanterBox]"
					Tooltip: While in a Graveyard during Hardmode
				}

				DecorativeBannersFromCrates: {
					Label: "[i:789] Decorative Banners, Average Crates to Get [i:845]"
					Tooltip:
						'''
						Each Decorative Banner will have a 1 out of n chance of dropping from a
						matching Biome Crate, where n equals this setting. Set to 0 to disable.
						'''
				}
			}

			TravelingMerchantConfig: {
				DisplayName: 05 [i:2222] Traveling Merchant

				TravelingMerchantChatsItems: {
					Label: Traveling Merchant Announces Items on Arrival
					Tooltip:
						'''
						The chat will display icons for all items in the shop (similar to
						when a player Alt-Clicks an inventory item when the chat is open)
						'''
				}

				Headers.MerchantDice:
					'''
					[i:ReducedGrinding/MerchantDice] Merchant Dice.

					For a limited amount of times per day, you can use this to re-roll the Traveling Merchant shop. The Traveling Merchant will only sell this when the amount of uses during the time that he appears is greater than 0.
