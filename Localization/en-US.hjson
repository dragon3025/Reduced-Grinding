# All localization happens in hjson files. These files contains the display names of content and other text values that will differ between languages.
# .hjson files contain translations for the language specified in the filename. (Make sure this file is UTF-8 encoded only.)
# The possible languages are: English ("en-US"), German ("de-DE"), Italian ("it-IT"), French ("fr-FR"), Spanish ("es-ES"), Russian ("ru-RU"), Chinese ("zh-Hans"), Portuguese ("pt-BR"), and Polish ("pl-PL")
# Localization files will be automatically updated with new content. After building and reloading the mod, new entries will appear in hjson files and can then be filled in.
# Here in ExampleMod we have organized these files in a folder called Localization. A single file per language makes it extremely easy to to integrate and maintain translations.
# Comments and non-autogenerated keys will be preserved and automatically mirrored to the non-English hjson files
# For more info on localization, see https://github.com/tModLoader/tModLoader/wiki/Localization

Mods: {
	ReducedGrinding: {
		InfoDisplays.LuckInfoDisplay.DisplayName: Luck Info

		Misc: {
			LuckInfoDisplay: Luck {0}%
			ClairvoyanceLuckTooltip: Displays Luck

			Fishing: {
				QuestFinishedText: You've given me {0} fish.
				CurrentQuest: Current Quest: [i:{0}].
				NewQuestText: The Angler decided to give you another quest!
				NewQuestTextWithIcon: The Angler decided to give you another quest: [i:{0}]!
				BumblebeeTunaIncrease: There is an outbreak of [i:BumblebeeTuna] Bumblebee Tuna, the Angler wants it!
			}

			DifficultyStaves: {
				CantUseInJourneyMode: This can't be used in a Journey World. Use the Journey Power Menu.
				DifficultySwitched: "[c/{0}:The world's difficulty has been set to {1}!]"
				GetGoodModification: '''[c/{0}: The world's Special Seed, "For the Worthy", increases this to {1}!]'''
				VoteCount: "[c/{0}:{1}], difficulty requested. To vote to change the world difficulty, use the matching staff. Total votes to switch difficulty out of votes needed: {2}/{3}!"
				VotingTimeUp: The voting time is up. The world difficulty didn't change!
				DifficultyIsTheSame: The world is already using this difficulty.
				WaitForVotingTimeToEnd: Someone is already requesting another difficulty. Wait for the voting time to end.
				AlreadyVoted: You already voted for this difficulty.
				GetGoodWillModifyDifficulty: The world's Special Seed, "For the Worthy", will increase this to [c/{0}:{1}!]
			}

			MerchantDice: {
				ReRollsLeft: Traveling Merchant shop re-rolled! Re-rolls left: {0}.
				NoMoreReRolls: You have no more re-rolls left.
				MerchantMissing: The Traveling Merchant isn't around. Wait until he arrives.
			}

			MoonWatch: {
				BloodMoon: The Moon Watch doesn't work during the Blood Moon.
				MoonPhase: Moon phase is now {0}
			}

			WorldPeaceStandard: The invasion left!

			WorldGeneration: {
				MissingTreeLoot: Adding missing tree loot
				MissingShroomLoot: Adding missing shroom loot
				MissingPyramidLoot: Adding missing pyramid loot
				PlacingTerragrims: Placing Terragrims
				OtherEvilChestGen: Placing the other Evil Chest
			}

			ArrivalMessage: {
				OldMan: The Old Man arrived at the Dungeon.
				Cultists: The Cultists arrived at the Dungeon.
			}

			CantShimmerDoll: The doll speaks to you: "Not now."
			CantShimmerItem: This can't be shimmered right now.
			ClothierCursed: The Clothier has been cursed; he moved to the Dungeon!
			Epitaph.1: RIP
			HardmodeRemoved: The ancient spirits of light and dark have been sealed away.
			HardmodeReturned: The ancient spirits of light and dark have returned.

			ChaosElementalSwarm: {
				Start: The Underground Hallow is chaotic!
				End: The Underground Hallow is calm!
			}

			AverageKillsToGet: Average Kills to Drop

			TriangularArrows: {
				Up: "⏶ "
				Down: "⏷ "
				Left: "⏴ "
				Right: "⏵ "
			}

			WarStandardBattlePotionTooltip: Stronger Battle Potions will work during Invasions
			WarStandardBattleBuffTooltip:
				'''
				{$Buffs.WarStandard.Description}
				Stronger Battle Potions will work during invasions
				'''

			ConfigurationTooltips: {
				MainIngredient: Setting to none will disable the 1st of 2 recipes for this item.
				AlternateIngredient:
					'''
					This is useful if you're setting the main ingredient to a resource that has a
					counterpart, for example: Iron and Lead. Setting to none will disable the 2nd of
					2 recipes for this item.
					'''
			}

			NameTag: "{0}'s name is now {1}!"

			CelestialWard: {
				MoonLord: The Moon Lord is no longer approaching!
				Pillars: The Celestial creatures are gone!
			}

			UniversalPylonBestiaryFail: {
				Destination: "{$Net.CannotTeleportToPylonBecauseNotEnoughNPCs}. Complete the Bestiary to remove this limitation for the that Pylon."
				Nearby: "{$Net.CannotTeleportToPylonBecauseNotEnoughNPCsAtCurrentPylon}. Complete the Bestiary to remove this limitation for this Pylon."
				Tooltip:
					'''
					This Pylon requires 2 nearby Town NPCs until the Bestiary is complete,
					  this is an early U.Pylon nerf that can be disabled in the configurations
					  (Mod Configuration > Reduced Grinding > Other).
					'''
			}

			NotConsumedWhenCraftingJackStatue: Not consumed when crafting Jack Statue
		}

		Configs: {
			EnemyLootConfig: {
				DisplayName: 01 [i:RainbowCursor] Enemy Loot

				Headers: {
					Main:
						'''
						You can change item drop rates using the following configurations. [c/FF9900:The chance of the item dropping is 1 divided by n, where n equals the setting. Low = More Often, High = Less Often]. Set to the max amount to use the vanilla drop rate.

						Bosses
						'''
					Hallow: Hallow
					Dungeon: Dungeon
					Underworld: Underworld
					JungleTemple: Jungle Temple
					Surface: Surface
					Cavern: Cavern
					CorruptionAndCrimson: Corruption And Crimson
					Holiday: Holiday
					OtherVanilla: Other Vanilla
				}

				Binoculars: {
					Label: "[i: 1299] Binoculars, {$Misc.AverageKillsToGet}"
					Tooltip: If world difficulty is normal, this is multiplied by (4/3)
				}

				StellarTune: {
					Label: "[i:4715] Stellar Tune, {$Misc.AverageKillsToGet}"
					Tooltip: If world difficulty is normal, this is multiplied by (5/2)
				}

				RainbowCursor: {
					Label: "[i:5075] Rainbow Cursor, {$Misc.AverageKillsToGet}"
					Tooltip: ""
				}

				CoinGun: {
					Label: "[i:905] Coin Gun From Flying Dutchman, {$Misc.AverageKillsToGet}"
					Tooltip: ""
				}

				PrismaticDye: {
					Label: "[i:HallowBossDye] Prismatic Dye, {$Misc.AverageKillsToGet}"
					Tooltip: Drops 3 at a time.
				}

				TownNPCWeapons: {
					Label: "[i:3349] Town NPC Weapons, {$Misc.AverageKillsToGet}"
					Tooltip:
						'''
						With n equaling this setting: the average kills to drop Paintball Gun is
						n / 8 * 10 floored, but at least 1; and the average kills to drop Happy Grenades
						is n / 8 * 4 floored, but at least 1.
						'''
				}

				BiomeKey: {
					Label: "[i:1533] Biome Key, {$Misc.AverageKillsToGet}"
					Tooltip: This sets the same drop rate for each
				}

				BeamSword: {
					Label: "[i:723] Beam Sword, {$Misc.AverageKillsToGet}"
					Tooltip: ""
				}

				GoodieBag: {
					Label: "[i:1774] Goodie Bag, {$Misc.AverageKillsToGet}"
					Tooltip: Only drops during Halloween
				}

				Lens: {
					Label: "[i:38] Lens, {$Misc.AverageKillsToGet}"
					Tooltip:
						'''
						Lens wont drop if Black Lens drops, so chance =
						(99 / 100) * (1 / setting)
						'''
				}

				LizardEgg: {
					Label: "[i:1172] Lizard Egg, {$Misc.AverageKillsToGet}"
					Tooltip: ""
				}

				Marrow: {
					Label: "[i:682] Marrow, {$Misc.AverageKillsToGet}"
					Tooltip: ""
				}

				PaladinsHammer: {
					Label: "[i:1513] Paladin's Hammer, {$Misc.AverageKillsToGet}"
					Tooltip: In Expert or harder worlds, the drop gets a 2nd roll if the first roll fails.
				}

				PlumbersHat: {
					Label: "[i:244] Plumber's Hat, {$Misc.AverageKillsToGet}"
					Tooltip: ""
				}

				Present: {
					Label: "[i:1869] Present, {$Misc.AverageKillsToGet}"
					Tooltip: Only drops during Christmas
				}

				RifleScopeAndSniperRifle: {
					Label: "[i:1300] Rifle Scope and [i:1254] Sniper Rifle, {$Misc.AverageKillsToGet}"
					Tooltip:
						'''
						This sets the same drop rate for each.

						In Expert or harder worlds, the drop gets a 2nd roll if the first roll fails.
						'''
				}

				RocketLauncher: {
					Label: "[i:759] Rocket Launcher, {$Misc.AverageKillsToGet}"
					Tooltip: In Expert or harder worlds, the drop gets a 2nd roll if the first roll fails.
				}

				RodofDiscord: {
					Label: "[i:1326] Rod of Discord, {$Misc.AverageKillsToGet}"
					Tooltip:
						'''
						If world difficulty is normal, this is multiplied by (5/4) (In a Celebrationmk10
						world, it's divided by 4, then rounded upwards if below 1).

						Consider "NPCs and Enemies > Chaos Elemental Swarm" when setting this.
						'''
				}

				RottenChunkAndVertebra: {
					Label: "[i:68] Rotten Chunk and [i:1330] Vertebra, {$Misc.AverageKillsToGet}"
					Tooltip: This sets the same drop rate for each
				}

				SoulOfLightAndNight: {
					Label: "[i:520] Soul of Light and [i:521] Soul of Night, {$Misc.AverageKillsToGet}"
					Tooltip: This sets the same drop rate for each
				}

				SWATHelmetAndTacticalShotgun: {
					Label: "[i:1514] SWAT Helmet and [i:679]Tactical Shotgun, {$Misc.AverageKillsToGet}"
					Tooltip:
						'''
						This sets the same drop rate for each.

						In Expert or harder worlds, the drop gets a 2nd roll if the first roll fails.
						'''
				}

				SlimeStaffFromPinky: {
					Label: "[i:SlimeStaff] Slime Staff, {$Misc.AverageKillsToGet}"
					Tooltip:
						'''
						If world difficulty is normal, this multiplied by (10/7). This is multiplied
						further by the Slime Type: Pinky, 1; Sand Slime, (5600/70); and Other:
						(7000/70). King Slime uses a seperate configuration.
						'''
				}

				PaladinsShield: {
					Label: "[i:938] Paladins Shield, {$Misc.AverageKillsToGet}"
					Tooltip: In Expert or harder worlds, the drop gets a 2nd roll if the first roll fails.
				}

				ObsidianRose: {
					Label: "[i:1323] Obsidian Rose, {$Misc.AverageKillsToGet}"
					Tooltip: ""
				}

				PresentMultiplierAfterPlantera: {
					Label: "[i:Present] Present Multiplier After [i:2109] Plantera"
					Tooltip:
						'''
						After Plantera, the amount of Presents dropped will be
						multiplied by this. Set to 1 for Vanilla behavior.
						'''
				}

				GoodieBagMultiplierAfterPlantera: {
					Label: "[i:1774] Goodie Bag Multiplier After [i:2109] Plantera"
					Tooltip:
						'''
						After Plantera, the amount of Goodie Bags dropped will
						be multiplied by this. Set to 1 for Vanilla behavior.
						'''
				}

				GuaranteedBiomeKey: {
					Label: "[i:1534] Guaranteed Biome Key, Kills to Get"
					Tooltip:
						'''
						A Biome Key will always drop after getting this many kills in a matching biome.
						Set to 0 to disable. If disabled, the kill count for each Guaranteed Key will be
						reset when the world is loaded.
						'''
				}

				GuaranteedBiomeKeyBehavior: {
					Label: "[i:1535] Guaranteed Biome Key Behavior"
					Tooltip: ""
				}

				SlimeStaffFromKingSlime: {
					Label: "[i:1309] Slime Staff From King Slime, {$Misc.AverageKillsToGet}"
					Tooltip: The default for this setting, uses the 1.4.5+ drop rate.
				}

				FishronWings: {
					Label: "[i:2609] Fishron Wings, {$Misc.AverageKillsToGet}"
					Tooltip: If the world difficulty is normal, this is multiplied by (3 / 2)
				}

				EmpressWings: {
					Label: "[i:4823] Empress Wings, {$Misc.AverageKillsToGet}"
					Tooltip: If the world difficulty is normal, this is multiplied by (3 / 2)
				}

				MaxBeetleHuskInNormal: {
					Label: "[i:BeetleHusk] Max Beetle Husk In Normal"
					Tooltip:
						'''
						This setting doesn't affect Expert or harder. This will change the max amount of
						Beetle Husk dropped by Golem. The min amount will be set to 4 plus 0-14
						depending on this setting. Set to 8 to use the vanilla amounts. 23 sets it to
						the Expert or harder amounts.
						'''
				}
			}

			BobberPotionConfig: {
				DisplayName: 04 [i:ReducedGrinding/BobberPotion] Bobber Potions

				Headers: {
					BobberPotions: "[i:ReducedGrinding/BobberPotion] Bobber Potion"
					GreaterBobberPotion: "[i:ReducedGrinding/GreaterBobberPotion] Greater Bobber Potion"
					SuperBobberPotion: "[i:ReducedGrinding/SuperBobberPotion] Super Bobber Potion"
				}

				BobberPotionIngredient: {
