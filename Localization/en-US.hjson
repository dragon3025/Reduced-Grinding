				}

				SpawnRatePresetDefault: {
					Label: Spawn Rate Preset Default
					Tooltip: ""
				}

				SpawnRatePresetLowPerformance: {
					Label: Spawn Rate Preset Low Performance
					Tooltip: ""
				}

				VanillaSpawnRate: {
					Label: "[i:BattlePotion] Battle Potion"
					Tooltip: When remaining Battle Buff duration is <= {$VanillaDuration.Label}
				}

				GreaterSpawnRate: {
					Label: "[i:ReducedGrinding/GreaterBattlePotion] Greater Battle Potion"
					Tooltip:
						'''
						When remaining Battle Buff duration is > {$VanillaDuration.Label}
						and <= {$GreaterDuration.Label}
						'''
				}

				SuperSpawnRate: {
					Label: "[i:ReducedGrinding/SuperBattlePotion] Super Battle Potion"
					Tooltip: When remaining Battle Buff duration is > {$GreaterDuration.Label}
				}

				BuffIconTiers: {
					Label: Buff Icon Tiers
					Tooltip: If enabled, each tier of Battle Buff will have a diffferent icon.
				}

				TownsRequireAllVillagersUnlocked: {
					Label: "[i:WoodenDoor] Towns Require All Villagers Unlocked"
					Tooltip:
						'''
						While in towns, Battle Buffs will use the vanilla rate of ×2 to prevent
						overpowered Critter spawning. This effect is disabled when all vanilla Villagers
						are unlocked. Set to 0 to disable.
						'''
