					Tooltip: "{$Misc.ConfigurationTooltips.MainIngredient}"
				}

				BobberPotionAlternateIngredient: {
					Label: "[i:AlchemyTable] Alternate Main Ingredient"
					Tooltip: "{$Misc.ConfigurationTooltips.AlternateIngredient}"
				}

				BobberPotionBonus: {
					Label: "[i:FishingBobber] Bobber Bonus"
					Tooltip: Adds this many bobbers when fishing.
				}

				GreaterBobberPotionIngredient: {
					Label: "{$Configs.BobberPotionConfig.BobberPotionIngredient.Label}"
